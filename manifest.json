{
  "manifest_version": 3,
  "name": "Saipos Tools",
  "version": "6.4.2",
  "description": "Extrai dados de vendas via API REST, calcula comissões por garçom e gera relatório.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "sidePanel"],
  "host_permissions": [
    "https://conta.saipos.com/*",
    "https://*.saipos.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Abrir Painel",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://conta.saipos.com/*"],
      "js": ["src/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://conta.saipos.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://conta.saipos.com/*"],
      "js": ["src/partial-payment.js"],
      "run_at": "document_idle"
    }
  ],
  "background": { "service_worker": "src/background.js" },
  "web_accessible_resources": [
    {
      "resources": ["src/report.js"],
      "matches": ["https://conta.saipos.com/*"]
    }
  ]
}
